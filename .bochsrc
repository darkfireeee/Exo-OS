# Bochs Configuration for Exo-OS SMP Testing
# 4 CPUs multiprocessor configuration

# Memory
megs: 128

# Boot from CD-ROM
boot: cdrom
ata0-master: type=cdrom, path="build/exo_os.iso", status=inserted

# CPU Configuration - 4 cores
cpu: count=4, ips=50000000, reset_on_triple_fault=1

# CPUID Configuration - Minimal
cpuid: vendor_string="GenuineIntel", brand_string="Intel(R) Core(TM) i7 CPU"

# Display
display_library: nogui

# VGA
vga: extension=vbe

# Serial port for kernel output
com1: enabled=1, mode=file, dev=serial.out

# Debug console on port 0xE9
port_e9_hack: enabled=1

# Logging
log: bochs.log
error: action=report
info: action=report
debug: action=ignore
panic: action=ask

# Debugger
magic_break: enabled=0
