// FIX-VRUNTIME-01 — Overflow dans should_preempt_on_wakeup()
//
// FICHIER : kernel/src/scheduler/policies/cfs.rs
//
// PROBLÈME :
//   pub fn should_preempt_on_wakeup(running, woken, _min_vruntime) -> bool {
//       ...
//       if woken_vr + CFS_WAKEUP_PREEMPT_NS < running_vr {  // ← BUG
//
//   Addition Rust standard sur u64 :
//     • Mode debug   → panic! si débordement
//     • Mode release → wraps silencieusement → INVERSION DE LA COMPARAISON
//
//   Cas pathologique : un thread tourne depuis très longtemps (vruntime élevé),
//   un nouveau thread se réveille. woken_vr ≈ min_vruntime peut être proche de
//   u64::MAX après des heures de runtime (min_vruntime croît sans borne).
//   CFS_WAKEUP_PREEMPT_NS = 1_000_000 ns → overflow à min_vruntime > u64::MAX - 1M.
//
// CORRECTION :
//   Utiliser wrapping_add pour l'addition ET wrapping_sub pour la comparaison.
//   La sémantique wrapping est correcte pour les vruntime CFS car l'ordre relatif
//   est ce qui compte (comme Linux : vruntime_compare utilise (s64)(a - b) < 0).
// ═══════════════════════════════════════════════════════════════════════════════

// REMPLACEMENT de la fonction should_preempt_on_wakeup() (version complète) :

pub fn should_preempt_on_wakeup(
    running:       &ThreadControlBlock,
    woken:         &ThreadControlBlock,
    _min_vruntime: u64,
) -> bool {
    // Ne préempter que si le thread actuel n'est pas RT.
    if running.priority.is_realtime() { return false; }

    let running_vr = running.vruntime.load(Ordering::Relaxed);
    let woken_vr   = woken.vruntime.load(Ordering::Relaxed);

    // FIX-VRUNTIME-01 : utiliser wrapping_add pour éviter le panic en debug
    // et le wrap silencieux en release lors de l'addition avec CFS_WAKEUP_PREEMPT_NS.
    //
    // Sémantique correcte : préempter si le thread réveillé a couru
    // significativement MOINS que le thread courant (en temps virtuel).
    // La comparaison wrapping préserve l'ordre relatif même après overflow u64.
    //
    // Équivalent Linux (kernel/sched/fair.c, wakeup_preempt_entity) :
    //   return (s64)(se->vruntime - curr->vruntime) < -(s64)ideal_runtime
    // Notre formulation wrapping est arithmétiquement équivalente.
    let woken_vr_bumped = woken_vr.wrapping_add(CFS_WAKEUP_PREEMPT_NS);
    if woken_vr_bumped < running_vr {
        CFS_WAKEUP_PREEMPT_COUNT.fetch_add(1, Ordering::Relaxed);
        return true;
    }
    false
}

// ─────────────────────────────────────────────────────────────────────────────
// CORRECTION SUPPLÉMENTAIRE — normalize_vruntime_on_enqueue()
//
// Même fichier, même problème potentiel :
//   let floor = min_vruntime.saturating_sub(slice_ns / 2);
// → saturating_sub est correct ici (pas de bug).
//
// Mais la comparaison current_vr < floor pour un thread dormant longtemps
// peut aussi nécessiter wrapping. Pas critique (normalisation approximative)
// mais documenter le comportement :
// ─────────────────────────────────────────────────────────────────────────────

pub fn normalize_vruntime_on_enqueue(tcb: &ThreadControlBlock, min_vruntime: u64, slice_ns: u64) {
    let current_vr = tcb.vruntime.load(Ordering::Relaxed);
    // saturating_sub correct : si min_vruntime < slice_ns/2, floor = 0 (conservateur).
    let floor = min_vruntime.saturating_sub(slice_ns / 2);
    if current_vr < floor {
        tcb.vruntime.store(floor, Ordering::Relaxed);
    }
}


