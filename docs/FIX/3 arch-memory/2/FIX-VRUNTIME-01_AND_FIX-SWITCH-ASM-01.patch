// FIX-SWITCH-ASM-01 — Désalignement de pile dans switch_to_new_thread
//
// FICHIER : kernel/src/scheduler/asm/switch_asm.s
//
// PROBLÈME :
//   switch_to_new_thread sauvegarde le thread SORTANT avec 16 octets de plus
//   que context_switch_asm (MXCSR + x87 FCW) :
//
//   switch_to_new_thread (sauvegarde OLD thread) :
//     pushq r15,r14,r13,r12,rbp,rbx    ; 48 octets
//     subq  $16, %rsp                  ; ← 16 OCTETS SUPPLÉMENTAIRES
//     stmxcsr 0(%rsp)                  ; sauvegarde MXCSR
//     fstcw   8(%rsp)                  ; sauvegarde x87 FCW
//     movq  %rsp, (%rdi)               ; kstack_ptr pointe 16 octets trop bas
//
//   context_switch_asm (restaure ce même thread plus tard) :
//     movq  %rsi, %rsp                 ; rsp = kstack_ptr (pointe sur MXCSR)
//     popq  %rbx                       ; ← charge MXCSR dans rbx  ← CORROMPU
//     popq  %rbp                       ; ← charge FCW dans rbp    ← CORROMPU
//     popq  %r12,%r13,%r14,%r15        ; charges des valeurs décalées
//     ret                              ; ← saute vers une adresse aléatoire CRASH
//
//   Le commentaire dans create.rs dit explicitement (SANS MXCSR/FCW) —
//   contrat documenté mais VIOLÉ dans l'ASM.
//
// RACINE : incohérence de refactoring. V7-C-02 a supprimé MXCSR/FCW de
//   context_switch_asm mais oublié de faire de même dans switch_to_new_thread.
//
// CORRECTION :
//   Supprimer les 3 lignes (subq + stmxcsr + fstcw) de switch_to_new_thread.
//   Le layout de sauvegarde du VIEUX thread devient identique à context_switch_asm.
// ═══════════════════════════════════════════════════════════════════════════════

