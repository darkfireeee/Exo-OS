// ═══════════════════════════════════════════════════════════════════════════════
// FIX-KPTI-01 — Rendre CURRENT_CR3_KERNEL/USER per-CPU dans kpti.rs
//
// PROBLÈME :
//   kernel/src/arch/x86_64/spectre/kpti.rs déclare :
//     static CURRENT_CR3_KERNEL: AtomicU64 = AtomicU64::new(0); // ← GLOBAL
//     static CURRENT_CR3_USER:   AtomicU64 = AtomicU64::new(0); // ← GLOBAL
//
//   Sur SMP à N CPUs, CPU1 appelle set_current_cr3() et écrase les valeurs de CPU0.
//   Quand CPU0 appelle kpti_switch_to_user() ensuite, il charge le CR3 de CPU1 → UB.
//
//   kpti_split.rs a déjà une structure per-CPU (KptiTable.states[cpu_id]) mais
//   kpti.rs ne l'exploite pas — les deux mécanismes coexistent de façon incohérente.
//
// SOLUTION :
//   Remplacer les deux AtomicU64 globaux par un tableau per-CPU aligné sur
//   des cache lines distinctes, indexé par cpu_id.
//   → Même pattern que PREEMPT_COUNT dans preempt.rs (déjà corrigé CORR-27).
//
// FICHIER MODIFIÉ : kernel/src/arch/x86_64/spectre/kpti.rs
// ═══════════════════════════════════════════════════════════════════════════════

use core::sync::atomic::{AtomicBool, AtomicU64, Ordering};
use super::super::smp::percpu;

// ── Constante MAX_CPUS ────────────────────────────────────────────────────────
// Importer depuis le module canonique, ne pas redéfinir localement.
use crate::arch::x86_64::smp::percpu::MAX_CPUS;

// ── État global KPTI ──────────────────────────────────────────────────────────

static KPTI_ENABLED: AtomicBool = AtomicBool::new(false);

pub fn kpti_enabled() -> bool {
    KPTI_ENABLED.load(Ordering::Relaxed)
}

// ── Bit PCID ─────────────────────────────────────────────────────────────────

const CR3_PCID_MASK:    u64 = 0xFFF;
const CR3_NO_FLUSH_BIT: u64 = 1u64 << 63;

pub const PCID_KERNEL: u64 = 0;
pub const PCID_USER:   u64 = 1;

// ── CR3 per-CPU — REMPLACEMENT DES GLOBAUX ────────────────────────────────────
//
// AVANT (BUG) :
//   static CURRENT_CR3_KERNEL: AtomicU64 = AtomicU64::new(0);  // 1 seul pour tous
//   static CURRENT_CR3_USER:   AtomicU64 = AtomicU64::new(0);  // 1 seul pour tous
//
// APRÈS (CORRIGÉ) :
//   Un slot de 128 octets par CPU (2 × AtomicU64 + padding cache line).
//   Séparation garantie par l'alignement align(128) → pas de false sharing.

/// Slot CR3 per-CPU : kernel_cr3 + user_cr3 sur une même cache line dédiée.
#[repr(C, align(128))]
struct Cr3Slot {
    kernel: AtomicU64,
    user:   AtomicU64,
    _pad:   [u8; 112], // 128 - 2×8 = 112
}

impl Cr3Slot {
    const fn new() -> Self {
        Self {
            kernel: AtomicU64::new(0),
            user:   AtomicU64::new(0),
            _pad:   [0u8; 112],
        }
    }
}

// SAFETY : accès par cpu_id exclusif → Sync garanti.
unsafe impl Sync for Cr3Slot {}

/// Tableau per-CPU des CR3 kernel+user.
/// MAX_CPUS × 128 octets = 32 KiB (négligeable pour un noyau).
static CR3_PER_CPU: [Cr3Slot; MAX_CPUS] = {
    const SLOT: Cr3Slot = Cr3Slot::new();
    [SLOT; MAX_CPUS]
};

// ── Helpers d'accès per-CPU ───────────────────────────────────────────────────

#[inline(always)]
fn current_cpu_slot() -> &'static Cr3Slot {
    // SAFETY : current_cpu_id() retourne toujours une valeur < MAX_CPUS.
    let cpu_id = percpu::current_cpu_id() as usize;
    &CR3_PER_CPU[cpu_id.min(MAX_CPUS - 1)]
}

// ── API publique ──────────────────────────────────────────────────────────────

/// Enregistre le couple (cr3_kernel, cr3_user) pour le thread courant sur CE CPU.
///
/// DOIT être appelé après chaque context switch qui change l'espace d'adressage,
/// ET lors de la construction initiale du thread (boot / fork).
///
/// # Changement vs l'ancienne API
/// L'écriture se fait dans le slot du CPU courant uniquement → thread-safe SMP.
pub fn set_current_cr3(cr3_kernel: u64, cr3_user: u64) {
    let slot = current_cpu_slot();
    // Release : garantit que les écritures précédentes (page tables) sont visibles
    // avant que ce CPU charge ces CR3.
    slot.kernel.store(cr3_kernel, Ordering::Release);
    slot.user.store(cr3_user,   Ordering::Release);
}

/// Bascule vers les tables de pages user (à exécuter avant IRETQ vers Ring 3).
///
/// ## RÈGLE DOC1 — KPTI
/// Lit le CR3 user du CPU COURANT uniquement → safe sur SMP.
#[inline]
pub unsafe fn kpti_switch_to_user() {
    if !KPTI_ENABLED.load(Ordering::Relaxed) { return; }
    let slot    = current_cpu_slot();
    let cr3_user = slot.user.load(Ordering::Acquire);
    if cr3_user == 0 { return; }

    let features = super::super::cpu::features::cpu_features();
    let cr3 = if features.has_pcid() {
        cr3_user | PCID_USER | CR3_NO_FLUSH_BIT
    } else {
        cr3_user & !CR3_PCID_MASK
    };
    // SAFETY: cr3_user validé par set_current_cr3 pour CE CPU.
    core::arch::asm!("mov cr3, {}", in(reg) cr3, options(nostack, nomem));
}

/// Bascule vers les tables de pages kernel (au retour vers Ring 0).
///
/// Lit le CR3 kernel du CPU COURANT uniquement → safe sur SMP.
#[inline]
pub unsafe fn kpti_switch_to_kernel() {
    if !KPTI_ENABLED.load(Ordering::Relaxed) { return; }
    let slot      = current_cpu_slot();
    let cr3_kernel = slot.kernel.load(Ordering::Acquire);
    if cr3_kernel == 0 { return; }

    let features = super::super::cpu::features::cpu_features();
    let cr3 = if features.has_pcid() {
        cr3_kernel | PCID_KERNEL | CR3_NO_FLUSH_BIT
    } else {
        cr3_kernel & !CR3_PCID_MASK
    };
    // SAFETY: cr3_kernel est le CR3 kernel courant validé pour CE CPU.
    core::arch::asm!("mov cr3, {}", in(reg) cr3, options(nostack, nomem));
}

// ─────────────────────────────────────────────────────────────────────────────
// INTÉGRATION AVEC context_switch() — FIX-KPTI-INC-05
//
// Le contexte switch dans switch.rs fait dans l'ASM :
//   movq %rdx, %cr3     ← CR3 physique switché
// Puis en Rust après le retour de context_switch_asm :
//   percpu::set_current_tcb(next)
//
// Pour garantir que kpti_switch_to_user/kernel() utilisent les bonnes valeurs
// immédiatement après un switch, appeler set_current_cr3() dans context_switch()
// APRÈS context_switch_asm() :
//
// Dans kernel/src/scheduler/core/switch.rs, après `next.set_state(Running)` :
//
//   // FIX-KPTI-01 : mettre à jour le slot per-CPU avec les CR3 de `next`.
//   // Nécessaire pour que kpti_switch_to_user/kernel() lisent les bons CR3
//   // dès le prochain syscall/exception sur ce CPU.
//   if crate::arch::x86_64::spectre::kpti::kpti_enabled() {
//       // user_cr3 = cr3_phys | PCID_USER pour le shadow. Si pas de shadow table,
//       // on stocke cr3_phys directement ; kpti_switch_to_user() appliquera le masque.
//       let user_cr3 = next.cr3_phys; // kpti_split gère le mapping shadow
//       crate::arch::x86_64::spectre::kpti::set_current_cr3(next.cr3_phys, user_cr3);
//   }
//
// Cela ferme également la fenêtre INC-05 (IRQ entre movq cr3 et maj Rust).
// ─────────────────────────────────────────────────────────────────────────────

// ── Initialisation (inchangée, conservée pour compatibilité) ─────────────────

pub fn init_kpti() {
    let features = super::super::cpu::features::cpu_features();

    if features.has_smep() {
        let mut cr4: u64;
        unsafe { core::arch::asm!("mov {}, cr4", out(reg) cr4, options(nostack, nomem)); }
        cr4 |= 1 << 20;
        unsafe { core::arch::asm!("mov cr4, {}", in(reg) cr4, options(nostack, nomem)); }
    }

    if features.has_smap() {
        let mut cr4: u64;
        unsafe { core::arch::asm!("mov {}, cr4", out(reg) cr4, options(nostack, nomem)); }
        cr4 |= 1 << 21;
        unsafe { core::arch::asm!("mov cr4, {}", in(reg) cr4, options(nostack, nomem)); }
    }

    let cpu_id = crate::arch::x86_64::smp::percpu::current_cpu_id() as usize;
    let kernel_pml4_phys = crate::memory::virt::page_table::read_cr3();
    let trampoline_phys  = crate::memory::core::PhysAddr::new(
        crate::arch::x86_64::smp::init::TRAMPOLINE_PHYS,
    );

    let user_shadow = unsafe {
        crate::memory::virt::page_table::kpti_split::build_user_shadow_pml4(kernel_pml4_phys)
    };

    match user_shadow {
        Ok(user_pml4_phys) => {
            unsafe {
                crate::memory::virt::page_table::kpti_split::KPTI.register_cpu(
                    cpu_id,
                    kernel_pml4_phys,
                    user_pml4_phys,
                    trampoline_phys,
                );
            }
            crate::memory::virt::page_table::kpti_split::KPTI.enable();

            // FIX-KPTI-01 : initialiser le slot per-CPU au moment de l'activation.
            // Avant ce correctif, set_current_cr3() écrivait dans un global → race SMP.
            set_current_cr3(kernel_pml4_phys.as_u64(), user_pml4_phys.as_u64());

            KPTI_ENABLED.store(true, Ordering::Release);
        }
        Err(_) => {
            log::warn!("KPTI: impossible d'allouer la user_pml4 shadow sur CPU {}", cpu_id);
        }
    }
}
